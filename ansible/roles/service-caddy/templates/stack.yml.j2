version: '3'
services:
  caddy:
    image: caddy:{{ caddy_version }}
    user: "{{ service_account.uid }}:{{ service_account.gid }}"
    restart: 'unless-stopped'
    networks:
      {{ stack_prefix }}services:
      {{ stack_prefix }}cloudflare:
    deploy:
      replicas: 1
      update_config:
        parallelism: 1
        delay: 30s
        failure_action: rollback
        monitor: 30s
        order: start-first
      rollback_config:
        parallelism: 1
        delay: 30s
        monitor: 60s
    volumes:
      - {{ stack_prefix }}caddy_data:/data
      - /opt/stacks/{{ stack_prefix }}caddy/Caddyfile:/etc/caddy/Caddyfile

volumes:
  {{ stack_prefix }}caddy_data:

networks:
  {{ stack_prefix }}services:
    external: true
  {{ stack_prefix }}cloudflare:
    external: true
